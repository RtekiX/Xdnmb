# Xcode build products and local caches
build/
DerivedData/
com.apple.DeveloperTools/
*.xcarchive
*.dSYM
*.dSYM.zip
*.ipa

# Xcode user-specific state
xcuserdata/
*.xcuserstate
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xccheckout
*.xcscmblueprint

# Dependency caches (the app currently has no external dependencies)
Pods/
.build/
.swiftpm/

# Local assistant and editor configuration
.claude/
.codex/
*.swp
*.orig

# Secrets and signing material
.env
.env.*
*.p12
*.mobileprovision

# macOS metadata
.DS_Store
